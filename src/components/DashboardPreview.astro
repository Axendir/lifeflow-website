---
---

<section class="relative py-24 sm:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-brand-violet mb-4">Aperçu</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-50 mb-4">
        Un tableau de bord qui <span class="text-gradient">vous comprend.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Modules personnalisables, synthèse matinale IA et vision 360° de votre journée.
      </p>
    </div>

    <!-- Mockup container -->
    <div class="reveal relative">
      <!-- Glow behind -->
      <div class="absolute inset-0 bg-brand-violet/5 blur-[80px] rounded-full"></div>

      <!-- Desktop mockup -->
      <div class="relative mx-auto max-w-5xl">
        <!-- Browser chrome -->
        <div class="bg-surface-800 rounded-t-2xl border border-slate-700 border-b-0 px-4 py-3 flex items-center gap-2">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="bg-surface-900 rounded-lg px-4 py-1 text-xs text-slate-500 flex items-center gap-2">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              app.lifehub.dev
            </div>
          </div>
        </div>
        <!-- SVG mockup -->
        <div class="border border-slate-700 border-t-0 rounded-b-2xl overflow-hidden">
          <img src="/mockup-web-dark.svg" alt="LifeHub — Tableau de bord" class="w-full h-auto" loading="lazy" />
        </div>
      </div>

      <!-- Mobile mockup floating -->
      <div class="absolute -bottom-8 -right-4 sm:right-8 lg:right-16 w-40 sm:w-52 reveal delay-300">
        <div class="bg-surface-900 rounded-[24px] border-2 border-slate-700 p-1.5 shadow-2xl">
          <!-- Phone notch -->
          <div class="absolute top-4 left-1/2 -translate-x-1/2 w-16 h-4 bg-surface-900 rounded-full z-10"></div>
          <img src="/mockup-mobile-dark.svg" alt="LifeHub Mobile" class="w-full h-auto rounded-[20px]" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>
