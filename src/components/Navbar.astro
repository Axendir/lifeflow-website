          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-surface-900/95 backdrop-blur-xl">
    <div class="px-6 py-4 space-y-3">
      <a href="#features" class="block text-sm text-slate-400 hover:text-slate-50 py-2">Fonctionnalités</a>
      <a href="#how-it-works" class="block text-sm text-slate-400 hover:text-slate-50 py-2">Comment ça marche</a>
      <a href="#ai" class="block text-sm text-slate-400 hover:text-slate-50 py-2">Intelligence IA</a>
      <a href="#connectors" class="block text-sm text-slate-400 hover:text-slate-50 py-2">Intégrations</a>
      <a href="#waitlist" class="btn-primary text-sm w-full justify-center mt-2">Accès anticipé</a>
