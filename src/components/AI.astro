---
const capabilities = [
  {
    title: "Synthèse matinale",
    description: "Chaque matin, une synthèse IA personnalisée : emails importants, agenda, santé, tâches prioritaires et recommandations.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
  },
  {
    title: "Assistant conversationnel",
    description: "Posez n'importe quelle question sur vos données. L'IA accède à vos emails, agenda, santé et notes en temps réel.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
  },
  {
    title: "Suggestions email",
    description: "Des brouillons de réponse générés automatiquement, adaptés à votre ton et au contexte de la conversation.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>`,
  },
  {
    title: "Analyse de santé",
    description: "Interprétation de vos analyses sanguines, détection d'anomalies, suivi des tendances et recommandations personnalisées.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
  },
  {
    title: "Score de risque mental",
    description: "Algorithmes prédictifs (PHQ-9, GAD-7, charge allostatique) pour une prévention proactive de votre santé mentale.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
  },
  {
    title: "Optimisation de prompts",
    description: "Atelier IA intégré pour créer, tester et optimiser vos prompts avec 3 niveaux de complexité.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
  },
]
---

<section id="ai" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: content -->
      <div class="reveal">
        <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-brand-violet mb-4">Intelligence artificielle</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-50 mb-4">
          Propulsé par <span class="text-gradient">l'IA.</span>
        </h2>
        <p class="text-lg text-slate-400 mb-8 leading-relaxed">
          L'IA ne remplace pas votre jugement — elle l'augmente. LifeHub utilise l'intelligence artificielle pour comprendre vos données, anticiper vos besoins et vous faire gagner du temps chaque jour.
        </p>

        <!-- Briefing preview card -->
        <div class="bg-gradient-to-br from-violet-700 to-pink-600 rounded-2xl p-6 shadow-lg shadow-violet-900/40">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-white/15 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
              </svg>
            </div>
            <div>
              <div class="text-[10px] font-semibold tracking-widest text-white/60 uppercase">Synthèse matinale IA</div>
              <div class="text-sm font-semibold text-white">Bonjour Jérémy — Jeudi 27 mars 2026</div>
            </div>
          </div>
          <div class="space-y-2 text-sm text-white/85">
            <p>3 tâches prioritaires aujourd'hui. Votre réunion Teams commence dans 2h.</p>
            <div class="flex gap-2 mt-3 flex-wrap">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white/15 text-xs text-white">
                🗓 2 événements
              </span>
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white/15 text-xs text-white">
                ✅ 5 tâches
              </span>
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white/15 text-xs text-white">
                💊 Rappel 8h
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: capabilities grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {capabilities.map((cap, i) => (
          <div class="reveal gradient-border p-5" style={`transition-delay: ${i * 80}ms`}>
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-brand-violet/10 text-brand-violet mb-3">
              <Fragment set:html={cap.icon} />
            </div>
            <h4 class="text-sm font-semibold text-slate-50 mb-1.5">{cap.title}</h4>
            <p class="text-xs text-slate-400 leading-relaxed">{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
