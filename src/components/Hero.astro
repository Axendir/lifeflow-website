---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full bg-brand-fuchsia/10 blur-[120px] animate-orb"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 rounded-full bg-brand-indigo/10 blur-[120px] animate-orb-slow"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-brand-violet/5 blur-[160px]"></div>
  </div>

  <!-- Dot grid -->
  <div class="absolute inset-0 dot-grid opacity-50"></div>

  <!-- Animated wave SVG -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] opacity-20 pointer-events-none">
    <svg viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="hero-wave-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#EC4899" />
          <stop offset="50%" stop-color="#A855F7" />
          <stop offset="100%" stop-color="#6366F1" />
        </linearGradient>
      </defs>
      <path
        d="M 0 100 C 50 100, 75 40, 125 40 C 175 40, 200 160, 250 160 C 300 160, 325 30, 400 30 C 475 30, 500 170, 550 170 C 600 170, 625 50, 675 50 C 725 50, 750 100, 800 100"
        stroke="url(#hero-wave-grad)"
        stroke-width="3"
        stroke-linecap="round"
        class="animate-wave"
      />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="animate-float-up inline-flex items-center gap-2 px-4 py-2 rounded-full border border-slate-700 bg-surface-800/60 backdrop-blur-sm mb-8">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="text-xs font-medium text-slate-300">Bientôt disponible — Accès anticipé 2026</span>
    </div>

    <!-- Headline -->
    <h1 class="animate-float-up delay-100 text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6">
      <span class="text-slate-50">Votre vie.</span><br />
      <span class="text-gradient">Unifiée. Intelligente.</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-float-up delay-200 text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      La couche d'intelligence qui relie toutes les dimensions de votre quotidien.
      Mails, calendrier, santé, finances et IA — centralisés en un seul endroit.
    </p>

    <!-- CTA buttons -->
    <div class="animate-float-up delay-300 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#waitlist" class="btn-primary text-base px-8 py-3.5">
        Rejoindre l'accès anticipé
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#features" class="btn-ghost text-base px-8 py-3.5">
        Découvrir
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div class="animate-float-up delay-500 mt-16 flex items-center justify-center gap-8 sm:gap-16">
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-slate-50">12+</div>
        <div class="text-xs sm:text-sm text-slate-500 mt-1">Intégrations</div>
      </div>
      <div class="w-px h-10 bg-slate-700"></div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-slate-50">6</div>
        <div class="text-xs sm:text-sm text-slate-500 mt-1">Dimensions de vie</div>
      </div>
      <div class="w-px h-10 bg-slate-700"></div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-slate-50">IA</div>
        <div class="text-xs sm:text-sm text-slate-500 mt-1">Propulsé par l'IA</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-5 h-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
