---

<section id="connectors" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-brand-violet mb-4">Intégrations</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-50 mb-4">
        Tous vos services, <span class="text-gradient">connectés.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Connexion sécurisée. Synchronisation en temps réel. Vos données restent les vôtres.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {connectors.map((connector, i) => (
        <div
          class="reveal group relative bg-surface-800 border border-slate-700 rounded-2xl p-6 flex flex-col items-center gap-3 card-hover cursor-default text-center"
          style={`transition-delay: ${i * 50}ms`}
        >
          <div class="text-slate-400 group-hover:text-brand-violet transition-colors">
            <Fragment set:html={connector.icon} />
          </div>
          <span class="text-sm font-semibold text-slate-200">{connector.name}</span>
          <span class="text-xs text-slate-500">{connector.description}</span>
        </div>
      ))}
    </div>
  </div>
</section>
