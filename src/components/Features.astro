---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>`,
    title: "Communication",
    description: "Gmail, Outlook et WhatsApp unifiés. Suggestions de réponses IA et tri intelligent de vos messages.",
    color: "bg-blue-500/10 text-blue-400",
    borderColor: "group-hover:border-blue-500/30",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Productivité",
    description: "Tâches, calendrier, notes Notion et suivi du temps. Pomodoro intégré et analytics de productivité.",
    color: "bg-indigo-500/10 text-indigo-400",
    borderColor: "group-hover:border-indigo-500/30",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    title: "Santé & Bien-être",
    description: "11 modules : sommeil, nutrition, humeur, méditation, addictions, analyses sanguines et plus encore.",
    color: "bg-emerald-500/10 text-emerald-400",
    borderColor: "group-hover:border-emerald-500/30",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Finances",
    description: "Suivi de solde, budgets et alertes. Intégration bancaire PSD2 pour une vision complète de vos finances.",
    color: "bg-amber-500/10 text-amber-400",
    borderColor: "group-hover:border-amber-500/30",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
    title: "Développement",
    description: "GitHub, bug tracker, PR review automatisée et veille technologique avec digest IA quotidien.",
    color: "bg-purple-500/10 text-purple-400",
    borderColor: "group-hover:border-purple-500/30",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: "Développement personnel",
    description: "Habitudes, objectifs, journal, lecture et méditation. Heatmaps et streaks pour rester motivé.",
    color: "bg-pink-500/10 text-pink-400",
    borderColor: "group-hover:border-pink-500/30",
  },
]
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-brand-violet mb-4">Fonctionnalités</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-50 mb-4">
        Six dimensions,<br /><span class="text-gradient">un seul endroit.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        LifeHub centralise et orchestre chaque aspect de votre vie grâce à l'intelligence artificielle.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature, i) => (
        <div class={`group reveal gradient-border p-6 cursor-default`} style={`transition-delay: ${i * 80}ms`}>
          <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl ${feature.color} mb-4`}>
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold text-slate-50 mb-2">{feature.title}</h3>
          <p class="text-sm text-slate-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
