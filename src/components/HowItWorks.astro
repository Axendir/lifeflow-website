---
const steps = [
  {
    number: "01",
    title: "Connectez",
    description: "Reliez vos services en un clic : mail, calendrier, notes, santé, musique, sport et plus encore. Connexion sécurisée, aucun mot de passe stocké.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.879a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 10-6.364 6.364L4.343 8.28" /></svg>`,
  },
  {
    number: "02",
    title: "Automatisez",
    description: "L'IA analyse vos données, génère votre synthèse matinale quotidienne, suggère des réponses email et détecte les anomalies dans votre santé.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>`,
  },
  {
    number: "03",
    title: "Pilotez",
    description: "Un tableau de bord intelligent avec modules personnalisables vous donne une vision à 360° de votre journée. Score quotidien, alertes et recommandations IA.",
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" /></svg>`,
  },
]
---

<section id="how-it-works" class="relative py-24 sm:py-32">
  <!-- Subtle line connecting steps -->
  <div class="absolute top-0 left-1/2 -translate-x-px w-px h-full bg-gradient-to-b from-transparent via-slate-700/50 to-transparent hidden lg:block"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-20 reveal">
      <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-brand-violet mb-4">Comment ça marche</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-50 mb-4">
        Trois étapes vers la <span class="text-gradient">clarté.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        La clarté est une forme de respect envers l'utilisateur.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, i) => (
        <div class="reveal relative text-center lg:text-left" style={`transition-delay: ${i * 150}ms`}>
          <!-- Number -->
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-surface-800 border border-slate-700 mb-6 relative">
            <span class="text-gradient font-bold text-lg">{step.number}</span>
            <!-- Pulse ring -->
            <div class="absolute inset-0 rounded-2xl border border-brand-violet/20 animate-ping opacity-20"></div>
          </div>

          <h3 class="text-2xl font-bold text-slate-50 mb-3">{step.title}</h3>
          <p class="text-slate-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
